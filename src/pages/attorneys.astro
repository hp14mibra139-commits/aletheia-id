<Layout
  title="Kontributor | Aletheia.id"
  description="Kenali para kontributor yang mendukung Aletheia.id melalui pendidikan hukum akademik, penelitian hukum, dan pengembangan konten berbasis mahasiswa."
  keywords="kontributor, peneliti hukum, pendidikan hukum akademik, penelitian hukum mahasiswa"
>
  <main>
    <section class="page-hero">
      <div class="container animate-on-scroll">
        <h1>Kontributor Kami</h1>
        <div class="breadcrumb">
          <a href="/">Beranda</a>
          <span class="separator">/</span>
          <span class="current">Kontributor</span>
        </div>
      </div>
    </section>

    <!-- Intro and Grid Section -->
    <section class="section attorneys-section">
      <div class="container">
        <p class="section-subtitle animate-on-scroll" style="margin-bottom: 4rem;">
          Profil kontributor di bawah ini menampilkan karya akademik and editorial yang mendukung Aletheia.id sebagai platform pendidikan hukum bagi mahasiswa, pembaca, and pencari ilmu.
        </p>

        <div class="attorneys-grid">
          {attorneys.map((lawyer) => (
            <div class="card attorney-card animate-on-scroll">
              <div class="attorney-avatar-wrapper">
                {lawyer.photo ? (
                  <img src={lawyer.photo} alt={lawyer.name} class="attorney-photo" />
                ) : (
                  <div class="attorney-avatar" style={`background-color: ${lawyer.color};`}>
                    {lawyer.initials}
                  </div>
                )}
              </div>
              
              <div class="attorney-details">
                <h3>{lawyer.name}</h3>
                <span class="attorney-role">{lawyer.role}</span>
                <span class="attorney-spec">{lawyer.specialization}</span>
                <p class="attorney-bio">{lawyer.bio}</p>
              </div>
              
              <div class="attorney-socials">
                <a
                  href={lawyer.instagram}
                  aria-label={`Profil Instagram ${lawyer.name}`}
                  class="social-icon-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z" />
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom Join Team CTA -->
    <section class="section join-team-cta" style="background-color: var(--gray-50); border-top: 1px solid var(--gray-200);">
      <div class="container text-center animate-on-scroll">
        <div class="cta-box">
          <h2>Tertarik untuk Berkontribusi pada Platform Ini?</h2>
          <p>
            Kami menyambut kerja sama yang baik, masukan akademik, and kontribusi yang mendukung pendidikan hukum serta pemahaman publik.
          </p>
          <a href="/contact" class="btn btn-outline">Hubungi Kami</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Attorneys Grid */
  .attorneys-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }

  .attorney-card {
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
  }

  .attorney-avatar-wrapper {
    margin-bottom: 2rem;
  }

  .attorney-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 1px;
    border: 3px solid var(--gold);
    box-shadow: var(--shadow-md);
    transition: var(--transition-base);
  }

  .attorney-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--gold);
    box-shadow: var(--shadow-md);
    transition: var(--transition-base);
  }

  .attorney-card:hover .attorney-avatar,
  .attorney-card:hover .attorney-photo {
    transform: scale(1.05);
    box-shadow: var(--shadow-gold), var(--shadow-lg);
  }

  .attorney-details {
    flex-grow: 1;
    margin-bottom: 2rem;
  }

  .attorney-details h3 {
    font-size: 1.5rem;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .attorney-role {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--gold-dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .attorney-spec {
    display: block;
    font-size: 0.85rem;
    color: var(--gray-500);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .attorney-bio {
    color: var(--gray-700);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .attorney-socials {
    display: flex;
    justify-content: center;
    gap: 2rem;
    width: 100%;
    border-top: 1px solid var(--gray-100);
    padding-top: 1.5rem;
  }

  .social-icon-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: var(--navy-light);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: var(--transition-base);
  }

  .social-icon-link:hover {
    color: var(--gold-dark);
  }

  .icon-label {
    font-weight: 500;
  }

  /* Bottom CTA Styling */
  .text-center {
    text-align: center;
  }

  .cta-box {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-box h2 {
    font-size: 2.2rem;
    color: var(--navy);
    margin-bottom: 1rem;
  }

  .cta-box p {
    color: var(--gray-700);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .attorneys-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .attorney-card {
      padding: 2.5rem 1.5rem;
    }
    .cta-box h2 {
      font-size: 1.8rem;
    }
  }
</style>

